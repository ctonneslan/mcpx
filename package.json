{
  "name": "mcpwire",
  "version": "0.1.0",
  "description": "The simplest way to connect to MCP servers. Two lines to connect, one line to call tools.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "llm",
    "tools",
    "agents",
    "claude",
    "openai",
    "anthropic"
  ],
  "author": "Charlie Tonneslan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ctonneslan/mcpwire.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
